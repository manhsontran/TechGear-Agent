# ── LLM ────────────────────────────────────────────────────────────────────────
# Lấy tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ── Telegram ────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Public URL where FastAPI is accessible (ngrok for local dev)
# Local dev (uvicorn trực tiếp): dùng port 8080 nếu 8000 bị Docker Desktop chiếm
# Docker container: mặc định port 8000 (xem docker-compose.yml)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Google Sheets ───────────────────────────────────────────────────────────────
# Paste the entire service account JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# The ID found in the Google Sheet URL
GOOGLE_SHEET_ID=your-google-sheet-id

# ── ChromaDB ────────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=techgear_knowledge_base

# ── Embedding ───────────────────────────────────────────────────────────────────
# Options: "gemini" | "sentence-transformers"
# sentence-transformers = offline, Vietnamese-friendly (recommended)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# ── LLM ─────────────────────────────────────────────────────────────────────────
# Options: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-1.5-pro
LLM_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.2

# ── RAG ──────────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3

# ── App ──────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── LangSmith (Observability & Tracing) ──────────────────────────────────────────
# Đăng ký tại: https://smith.langchain.com → Settings → API Keys
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=techgear-agent
